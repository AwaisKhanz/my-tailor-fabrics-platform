# API baseline env (shared defaults)
NODE_ENV=development
TZ=Asia/Karachi
PORT=3001

DATABASE_URL=postgresql://tbms:password@localhost:5432/tbms?schema=public
DIRECT_URL=postgresql://tbms:password@localhost:5432/tbms?schema=public

REDIS_URL=redis://localhost:6379
TRUST_PROXY=false

FRONTEND_URL=http://localhost:3000

JWT_SECRET=dev-only-jwt-secret-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-only-jwt-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_ROTATION_GRACE_SECONDS=30
STATUS_PIN_PEPPER=dev-only-status-pin-pepper-change-me
ENABLE_INTERNAL_SCHEDULER=true
SEED_CORE_DATA=false
SEED_DEMO_DATA=false

ENABLE_PUBLIC_MAIL_ENDPOINTS=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_EMAIL=
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
