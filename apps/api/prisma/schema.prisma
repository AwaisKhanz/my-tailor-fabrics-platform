generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id                String                @id @default(cuid())
  code              String                @unique
  name              String
  address           String?
  phone             String?
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  attendanceRecords AttendanceRecord[]
  customers         Customer[]
  employees         Employee[]
  expenses          Expense[]
  orders            Order[]
  rateCards         RateCard[]
  users             User[]
  ledgerEntries     EmployeeLedgerEntry[]
  salaryAccruals    SalaryAccrual[]
  designTypes       DesignType[]
}

model User {
  id                   String                         @id @default(cuid())
  name                 String
  email                String                         @unique
  passwordHash         String
  role                 Role                           @default(ENTRY_OPERATOR)
  branchId             String?
  employeeId           String?                        @unique
  isActive             Boolean                        @default(true)
  lastLoginAt          DateTime?
  refreshToken         String?
  previousRefreshToken String?
  previousRefreshTokenExpiresAt DateTime?
  pendingLoginChallengeId String?                     @unique
  pendingLoginOtpHash  String?
  pendingLoginOtpExpiresAt DateTime?
  pendingLoginOtpAttempts Int                         @default(0)
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  deletedAt            DateTime?
  auditLogs            AuditLog[]
  priceLogs            GarmentPriceLog[]
  rateCardsCreated     RateCard[]
  taskAssignmentEvents OrderItemTaskAssignmentEvent[]
  paymentsProcessed    Payment[]
  paymentsReversed     Payment[]                      @relation("PaymentReversedBy")
  orderPaymentsReversed OrderPayment[]               @relation("OrderPaymentReversedBy")
  ledgerEntries        EmployeeLedgerEntry[]
  ledgerEntriesReversed EmployeeLedgerEntry[]        @relation("LedgerEntryReversedBy")
  generatedSalaryAccruals SalaryAccrual[]           @relation("SalaryAccrualGeneratedBy")
  createdEmployeeCapabilities EmployeeCapability[]  @relation("EmployeeCapabilityCreatedBy")
  changedEmployeeCompensations EmployeeCompensationHistory[] @relation("EmployeeCompensationChangedBy")
  branch               Branch?                        @relation(fields: [branchId], references: [id])
  employee             Employee?                      @relation(fields: [employeeId], references: [id])

  @@index([branchId])
  @@index([role])
}

model Employee {
  id                String                   @id @default(cuid())
  employeeCode      String                   @unique
  branchId          String
  fullName          String
  fatherName        String?
  phone             String
  phone2            String?
  address           String?
  city              String?
  cnic              String?                  @unique
  dateOfBirth       DateTime?
  dateOfJoining     DateTime                 @default(now())
  employmentEndDate DateTime?
  designation       String?
  paymentType       PaymentType              @default(PER_PIECE)
  monthlySalary     Int?
  accountNumber     String?
  emergencyName     String?
  emergencyPhone    String?
  photoUrl          String?
  status            EmployeeStatus           @default(ACTIVE)
  notes             String?
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  attendanceRecords AttendanceRecord[]
  branch            Branch                   @relation(fields: [branchId], references: [id])
  documents         EmployeeDocument[]
  assignedTasks     OrderItemTask[]
  payments          Payment[]
  userAccount       User?
  ledgerEntries     EmployeeLedgerEntry[]
  salaryAccruals    SalaryAccrual[]
  capabilities      EmployeeCapability[]
  compensationHistory EmployeeCompensationHistory[]

  @@index([branchId, status])
  @@index([searchVector], type: Gin)
}

model EmployeeDocument {
  id           String    @id @default(cuid())
  employeeId   String
  label        String
  fileUrl      String
  fileType     String
  uploadedById String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  employee     Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model EmployeeCapability {
  id           String      @id @default(cuid())
  employeeId   String
  garmentTypeId String?
  stepKey      String?
  effectiveFrom DateTime
  effectiveTo  DateTime?
  note         String?
  createdById  String?
  createdAt    DateTime    @default(now())
  deletedAt    DateTime?
  employee     Employee    @relation(fields: [employeeId], references: [id])
  garmentType  GarmentType? @relation(fields: [garmentTypeId], references: [id])
  createdBy    User?       @relation("EmployeeCapabilityCreatedBy", fields: [createdById], references: [id])

  @@index([employeeId, effectiveFrom, effectiveTo])
  @@index([employeeId, garmentTypeId, stepKey, effectiveFrom])
  @@index([garmentTypeId, stepKey, effectiveFrom])
}

model EmployeeCompensationHistory {
  id           String      @id @default(cuid())
  employeeId   String
  paymentType  PaymentType
  monthlySalary Int?
  effectiveFrom DateTime
  effectiveTo  DateTime?
  note         String?
  changedById  String?
  createdAt    DateTime    @default(now())
  employee     Employee    @relation(fields: [employeeId], references: [id])
  changedBy    User?       @relation("EmployeeCompensationChangedBy", fields: [changedById], references: [id])

  @@index([employeeId, effectiveFrom, effectiveTo])
  @@index([paymentType, effectiveFrom, effectiveTo])
}

model Customer {
  id            String                   @id @default(cuid())
  branchId      String
  sizeNumber    String                   @unique
  fullName      String
  phone         String
  whatsapp      String?
  email         String?
  address       String?
  city          String?
  notes         String?
  status        CustomerStatus           @default(ACTIVE)
  isVip         Boolean                  @default(false)
  lifetimeValue Int                      @default(0)
  searchVector  Unsupported("tsvector")?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  deletedAt     DateTime?
  branch        Branch                   @relation(fields: [branchId], references: [id])
  measurements  CustomerMeasurement[]
  orders        Order[]

  @@index([branchId, deletedAt])
  @@index([sizeNumber])
  @@index([searchVector], type: Gin)
}

model MeasurementCategory {
  id           String                @id @default(cuid())
  name         String
  sortOrder    Int                   @default(0)
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  deletedAt    DateTime?
  updatedAt    DateTime              @updatedAt
  measurements CustomerMeasurement[]
  fields       MeasurementField[]
  sections     MeasurementSection[]
  garmentTypes GarmentType[]         @relation("GarmentTypeToMeasurementCategory")
}

model MeasurementSection {
  id         String              @id @default(cuid())
  categoryId String
  name       String
  sortOrder  Int                 @default(0)
  deletedAt  DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  category   MeasurementCategory @relation(fields: [categoryId], references: [id])
  fields     MeasurementField[]

  @@index([categoryId, sortOrder])
  @@index([categoryId, deletedAt, sortOrder])
}

model MeasurementField {
  id              String              @id @default(cuid())
  categoryId      String
  sectionId       String?
  label           String
  fieldType       FieldType           @default(NUMBER)
  unit            String?
  isRequired      Boolean             @default(false)
  sortOrder       Int                 @default(0)
  dropdownOptions String[]
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  category        MeasurementCategory @relation(fields: [categoryId], references: [id])
  section         MeasurementSection? @relation(fields: [sectionId], references: [id])

  @@index([sectionId])
}

model CustomerMeasurement {
  id         String              @id @default(cuid())
  customerId String
  categoryId String
  values     Json
  valuesMeta Json?
  updatedAt  DateTime            @updatedAt
  createdAt  DateTime            @default(now())
  category   MeasurementCategory @relation(fields: [categoryId], references: [id])
  customer   Customer            @relation(fields: [customerId], references: [id])

  @@unique([customerId, categoryId])
}

model GarmentType {
  id                    String                 @id @default(cuid())
  name                  String
  customerPrice         Int
  description           String?
  sortOrder             Int                    @default(0)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  priceLogs             GarmentPriceLog[]
  orderItems            OrderItem[]
  rateCards             RateCard[]
  workflowSteps         WorkflowStepTemplate[]
  measurementCategories MeasurementCategory[]  @relation("GarmentTypeToMeasurementCategory")
  designTypes           DesignType[]
  employeeCapabilities  EmployeeCapability[]
}

model Order {
  id             String                   @id @default(cuid())
  orderNumber    String                   @unique
  branchId       String
  customerId     String
  orderDate      DateTime                 @default(now())
  dueDate        DateTime
  subtotal       Int
  discountType   DiscountType?
  discountValue  Int                      @default(0)
  discountAmount Int                      @default(0)
  totalAmount    Int
  totalPaid      Int                      @default(0)
  balanceDue     Int
  notes          String?
  status         OrderStatus              @default(NEW)
  createdById    String
  shareToken     String?                  @unique
  sharePin       String?
  sharePinHash   String?
  sharePinMigratedAt DateTime?
  searchVector   Unsupported("tsvector")?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?
  branch         Branch                   @relation(fields: [branchId], references: [id])
  customer       Customer                 @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  payments       OrderPayment[]
  statusHistory  OrderStatusHistory[]

  @@index([branchId, status])
  @@index([customerId])
  @@index([dueDate])
  @@index([searchVector], type: Gin)
}

model OrderItem {
  id              String           @id @default(cuid())
  orderId         String
  garmentTypeId   String
  garmentTypeName String
  quantity        Int              @default(1)
  unitPrice       Int
  description     String?
  dueDate         DateTime?
  status          ItemStatus       @default(PENDING)
  completedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  fabricSource    FabricSource     @default(SHOP)
  pieceNo         Int              @default(1)
  garmentType     GarmentType      @relation(fields: [garmentTypeId], references: [id])
  order           Order            @relation(fields: [orderId], references: [id])
  tasks           OrderItemTask[]
  addons          OrderItemAddon[]
  designTypeId    String?
  designType      DesignType?      @relation(fields: [designTypeId], references: [id])

  @@unique([orderId, garmentTypeId, pieceNo])
  @@index([orderId])
  @@index([garmentTypeId])
}

model OrderPayment {
  id           String    @id @default(cuid())
  orderId      String
  amount       Int
  paidAt       DateTime  @default(now())
  receivedById String
  note         String?
  reversedAt   DateTime?
  reversedById String?
  reversalNote String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  order        Order     @relation(fields: [orderId], references: [id])
  reversedBy   User?     @relation("OrderPaymentReversedBy", fields: [reversedById], references: [id])

  @@index([orderId])
  @@index([reversedAt])
}

model OrderStatusHistory {
  id          String       @id @default(cuid())
  orderId     String
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedById String?
  actor       String       @default("USER")
  note        String?
  createdAt   DateTime     @default(now())
  order       Order        @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Payment {
  id            String                @id @default(cuid())
  employeeId    String
  amount        Int
  paidAt        DateTime              @default(now())
  processedById String
  note          String?
  reversedAt    DateTime?
  reversedById  String?
  reversalNote  String?
  deletedAt     DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  employee      Employee              @relation(fields: [employeeId], references: [id])
  processedBy   User                  @relation(fields: [processedById], references: [id])
  reversedBy    User?                 @relation("PaymentReversedBy", fields: [reversedById], references: [id])
  ledgerEntries EmployeeLedgerEntry[]

  @@index([employeeId, paidAt])
  @@index([reversedAt])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

model Expense {
  id          String          @id @default(cuid())
  branchId    String
  categoryId  String
  amount      Int
  description String?
  receiptUrl  String?
  expenseDate DateTime
  addedById   String
  createdAt   DateTime        @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime        @updatedAt
  branch      Branch          @relation(fields: [branchId], references: [id])
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([branchId, expenseDate])
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String?
  actorEmail String?
  action    String
  entity    String
  entityId  String
  branchId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User?     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  employeeId  String
  branchId    String
  date        DateTime
  clockIn     DateTime
  clockOut    DateTime?
  hoursWorked Float?
  note        String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime  @updatedAt
  branch      Branch    @relation(fields: [branchId], references: [id])
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
  @@index([branchId, date])
}

model GarmentPriceLog {
  id               String      @id @default(cuid())
  garmentTypeId    String
  changedById      String
  oldCustomerPrice Int?
  newCustomerPrice Int?
  action           String
  createdAt        DateTime    @default(now())
  changedBy        User        @relation(fields: [changedById], references: [id])
  garmentType      GarmentType @relation(fields: [garmentTypeId], references: [id])

  @@index([garmentTypeId])
  @@index([createdAt])
}

model WorkflowStepTemplate {
  id            String          @id @default(cuid())
  garmentTypeId String
  stepKey       String
  stepName      String
  sortOrder     Int             @default(0)
  isRequired    Boolean         @default(true)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  deletedAt     DateTime?
  tasks         OrderItemTask[]
  rateCards     RateCard[]
  garmentType   GarmentType     @relation(fields: [garmentTypeId], references: [id])

  @@unique([garmentTypeId, stepKey])
  @@index([garmentTypeId, sortOrder])
}

model RateCard {
  id             String                @id @default(cuid())
  branchId       String?
  branch         Branch?               @relation(fields: [branchId], references: [id])
  garmentTypeId  String
  garmentType    GarmentType           @relation(fields: [garmentTypeId], references: [id])
  stepTemplateId String?
  stepTemplate   WorkflowStepTemplate? @relation(fields: [stepTemplateId], references: [id])
  stepKey        String
  amount         Int
  effectiveFrom  DateTime              @default(now())
  effectiveTo    DateTime?
  createdById    String
  createdBy      User                  @relation(fields: [createdById], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?
  tasks          OrderItemTask[]

  @@index([garmentTypeId, stepKey, branchId])
  @@index([branchId])
}

model OrderItemTask {
  id                 String                         @id @default(cuid())
  orderItemId        String
  stepTemplateId     String?
  stepKey            String
  stepName           String
  sortOrder          Int                            @default(0)
  status             TaskStatus                     @default(PENDING)
  assignedEmployeeId String?
  startedAt          DateTime?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  deletedAt          DateTime?
  rateCardId         String?
  rateOverride       Int?
  rateSnapshot       Int?
  designRateSnapshot Int?
  assignedEmployee   Employee?                      @relation(fields: [assignedEmployeeId], references: [id])
  orderItem          OrderItem                      @relation(fields: [orderItemId], references: [id])
  rateCard           RateCard?                      @relation(fields: [rateCardId], references: [id])
  stepTemplate       WorkflowStepTemplate?          @relation(fields: [stepTemplateId], references: [id])
  designTypeId       String?
  designType         DesignType?                    @relation(fields: [designTypeId], references: [id])
  assignmentEvents   OrderItemTaskAssignmentEvent[]
  ledgerEntries      EmployeeLedgerEntry[]

  @@index([orderItemId, sortOrder])
  @@index([assignedEmployeeId, status])
  @@index([stepKey])
}

model OrderItemTaskAssignmentEvent {
  id             String        @id @default(cuid())
  taskId         String
  fromEmployeeId String?
  toEmployeeId   String?
  changedById    String?
  note           String?
  createdAt      DateTime      @default(now())
  changedBy      User?         @relation(fields: [changedById], references: [id])
  task           OrderItemTask @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

model SystemSettings {
  id              String   @id @default("default")
  useTaskWorkflow Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ENTRY_OPERATOR
  VIEWER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  LEFT
}

enum PaymentType {
  PER_PIECE
  MONTHLY_FIXED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum FieldType {
  NUMBER
  TEXT
  DROPDOWN
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  READY
  OVERDUE
  DELIVERED
  COMPLETED
  CANCELLED
}

enum ItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum FabricSource {
  SHOP
  CUSTOMER
}

enum LedgerEntryType {
  EARNING
  PAYOUT
  ADVANCE
  DEDUCTION
  ADJUSTMENT
  SALARY
}

enum AddonType {
  EXTRA
  ALTERATION
  DESIGN_CHARGE
}

model DesignType {
  id String @id @default(cuid())

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  garmentTypeId String?
  garmentType   GarmentType? @relation(fields: [garmentTypeId], references: [id])

  name         String
  defaultPrice Int
  defaultRate  Int

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tasks     OrderItemTask[]
  orderItems OrderItem[]

  @@index([branchId, garmentTypeId])
}

model OrderItemAddon {
  id String @id @default(cuid())

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  type  AddonType @default(EXTRA)
  name  String
  price Int
  cost  Int?

  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([orderItemId])
}

model EmployeeLedgerEntry {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  type   LedgerEntryType
  amount Int // positive = earning, negative = payout/deduction

  orderItemTaskId String?
  orderItemTask   OrderItemTask? @relation(fields: [orderItemTaskId], references: [id])

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])
  reversedById String?
  reversedBy   User?   @relation("LedgerEntryReversedBy", fields: [reversedById], references: [id])
  reversalOfId String?
  reversalOf   EmployeeLedgerEntry? @relation("LedgerEntryReversal", fields: [reversalOfId], references: [id])
  reversalEntries EmployeeLedgerEntry[] @relation("LedgerEntryReversal")
  salaryAccrual SalaryAccrual?

  note      String?
  reversalNote String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  reversedAt DateTime?

  @@index([employeeId, createdAt])
  @@index([branchId, createdAt])
  @@index([orderItemTaskId])
  @@index([reversedAt])
  @@index([reversalOfId])
}

model SalaryAccrual {
  id            String              @id @default(cuid())
  employeeId    String
  employee      Employee            @relation(fields: [employeeId], references: [id])
  branchId      String
  branch        Branch              @relation(fields: [branchId], references: [id])
  periodYear    Int
  periodMonth   Int
  periodStart   DateTime
  periodEnd     DateTime
  daysInMonth   Int
  eligibleDays  Int
  amount        Int
  ledgerEntryId String              @unique
  ledgerEntry   EmployeeLedgerEntry @relation(fields: [ledgerEntryId], references: [id])
  generatedById String?
  generatedBy   User?               @relation("SalaryAccrualGeneratedBy", fields: [generatedById], references: [id])
  source        String              @default("MANUAL")
  createdAt     DateTime            @default(now())

  @@unique([employeeId, periodYear, periodMonth])
  @@index([branchId, periodYear, periodMonth])
}
