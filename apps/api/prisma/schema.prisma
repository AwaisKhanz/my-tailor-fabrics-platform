generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  address           String?
  phone             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  attendanceRecords AttendanceRecord[]
  customers         Customer[]
  employees         Employee[]
  expenses          Expense[]
  orders            Order[]
  rateCards         RateCard[]
  users             User[]
}

model User {
  id                   String                         @id @default(cuid())
  name                 String
  email                String                         @unique
  passwordHash         String
  role                 Role                           @default(ENTRY_OPERATOR)
  branchId             String?
  employeeId           String?                        @unique
  isActive             Boolean                        @default(true)
  lastLoginAt          DateTime?
  refreshToken         String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  deletedAt            DateTime?
  auditLogs            AuditLog[]
  priceLogs            GarmentPriceLog[]
  taskAssignmentEvents OrderItemTaskAssignmentEvent[]
  paymentsProcessed    Payment[]
  branch               Branch?                        @relation(fields: [branchId], references: [id])
  employee             Employee?                      @relation(fields: [employeeId], references: [id])

  @@index([branchId])
  @@index([role])
}

model Employee {
  id                String                   @id @default(cuid())
  employeeCode      String                   @unique
  branchId          String
  fullName          String
  fatherName        String?
  phone             String
  phone2            String?
  address           String?
  city              String?
  cnic              String?                  @unique
  dateOfBirth       DateTime?
  dateOfJoining     DateTime                 @default(now())
  designation       String?
  paymentType       PaymentType              @default(PER_PIECE)
  accountNumber     String?
  emergencyName     String?
  emergencyPhone    String?
  photoUrl          String?
  status            EmployeeStatus           @default(ACTIVE)
  notes             String?
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  attendanceRecords AttendanceRecord[]
  branch            Branch                   @relation(fields: [branchId], references: [id])
  documents         EmployeeDocument[]
  orderItems        OrderItem[]
  assignedTasks     OrderItemTask[]
  payments          Payment[]
  userAccount       User?

  @@index([branchId, status])
  @@index([searchVector], type: Gin)
}

model EmployeeDocument {
  id           String    @id @default(cuid())
  employeeId   String
  label        String
  fileUrl      String
  fileType     String
  uploadedById String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  employee     Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model Customer {
  id            String                   @id @default(cuid())
  branchId      String
  sizeNumber    String                   @unique
  fullName      String
  phone         String
  whatsapp      String?
  email         String?
  address       String?
  city          String?
  notes         String?
  status        CustomerStatus           @default(ACTIVE)
  isVip         Boolean                  @default(false)
  lifetimeValue Int                      @default(0)
  searchVector  Unsupported("tsvector")?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  deletedAt     DateTime?
  branch        Branch                   @relation(fields: [branchId], references: [id])
  measurements  CustomerMeasurement[]
  orders        Order[]

  @@index([branchId, deletedAt])
  @@index([sizeNumber])
  @@index([searchVector], type: Gin)
}

model MeasurementCategory {
  id           String                @id @default(cuid())
  name         String
  sortOrder    Int                   @default(0)
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  deletedAt    DateTime?
  updatedAt    DateTime              @updatedAt
  measurements CustomerMeasurement[]
  fields       MeasurementField[]
  garmentTypes GarmentType[]         @relation("GarmentTypeToMeasurementCategory")
}

model MeasurementField {
  id              String              @id @default(cuid())
  categoryId      String
  label           String
  fieldType       FieldType           @default(NUMBER)
  unit            String?
  isRequired      Boolean             @default(false)
  sortOrder       Int                 @default(0)
  dropdownOptions String[]
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  category        MeasurementCategory @relation(fields: [categoryId], references: [id])
}

model CustomerMeasurement {
  id         String              @id @default(cuid())
  customerId String
  categoryId String
  values     Json
  updatedAt  DateTime            @updatedAt
  createdAt  DateTime            @default(now())
  category   MeasurementCategory @relation(fields: [categoryId], references: [id])
  customer   Customer            @relation(fields: [customerId], references: [id])

  @@unique([customerId, categoryId])
}

model GarmentType {
  id                    String                 @id @default(cuid())
  name                  String
  customerPrice         Int
  employeeRate          Int
  description           String?
  sortOrder             Int                    @default(0)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  priceLogs             GarmentPriceLog[]
  orderItems            OrderItem[]
  rateCards             RateCard[]
  workflowSteps         WorkflowStepTemplate[]
  measurementCategories MeasurementCategory[]  @relation("GarmentTypeToMeasurementCategory")
}

model Order {
  id             String                   @id @default(cuid())
  orderNumber    String                   @unique
  branchId       String
  customerId     String
  orderDate      DateTime                 @default(now())
  dueDate        DateTime
  subtotal       Int
  discountType   DiscountType?
  discountValue  Int                      @default(0)
  discountAmount Int                      @default(0)
  totalAmount    Int
  totalPaid      Int                      @default(0)
  balanceDue     Int
  notes          String?
  status         OrderStatus              @default(NEW)
  createdById    String
  shareToken     String?                  @unique
  sharePin       String?
  searchVector   Unsupported("tsvector")?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?
  branch         Branch                   @relation(fields: [branchId], references: [id])
  customer       Customer                 @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  payments       OrderPayment[]
  statusHistory  OrderStatusHistory[]

  @@index([branchId, status])
  @@index([customerId])
  @@index([dueDate])
  @@index([searchVector], type: Gin)
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  garmentTypeId   String
  garmentTypeName String
  employeeId      String?
  quantity        Int             @default(1)
  unitPrice       Int
  employeeRate    Int
  description     String?
  dueDate         DateTime?
  status          ItemStatus      @default(PENDING)
  completedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  fabricSource    FabricSource    @default(SHOP)
  pieceNo         Int             @default(1)
  employee        Employee?       @relation(fields: [employeeId], references: [id])
  garmentType     GarmentType     @relation(fields: [garmentTypeId], references: [id])
  order           Order           @relation(fields: [orderId], references: [id])
  tasks           OrderItemTask[]

  @@unique([orderId, garmentTypeId, pieceNo])
  @@index([orderId])
  @@index([garmentTypeId])
  @@index([employeeId, status])
}

model OrderPayment {
  id           String    @id @default(cuid())
  orderId      String
  amount       Int
  paidAt       DateTime  @default(now())
  receivedById String
  note         String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  order        Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model OrderStatusHistory {
  id          String       @id @default(cuid())
  orderId     String
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedById String?
  actor       String       @default("USER")
  note        String?
  createdAt   DateTime     @default(now())
  order       Order        @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Payment {
  id            String    @id @default(cuid())
  employeeId    String
  amount        Int
  paidAt        DateTime  @default(now())
  processedById String
  note          String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id])
  processedBy   User      @relation(fields: [processedById], references: [id])

  @@index([employeeId, paidAt])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

model Expense {
  id          String          @id @default(cuid())
  branchId    String
  categoryId  String
  amount      Int
  description String?
  receiptUrl  String?
  expenseDate DateTime
  addedById   String
  createdAt   DateTime        @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime        @updatedAt
  branch      Branch          @relation(fields: [branchId], references: [id])
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([branchId, expenseDate])
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  branchId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  employeeId  String
  branchId    String
  date        DateTime
  clockIn     DateTime
  clockOut    DateTime?
  hoursWorked Float?
  note        String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime  @updatedAt
  branch      Branch    @relation(fields: [branchId], references: [id])
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
  @@index([branchId, date])
}

model GarmentPriceLog {
  id               String      @id @default(cuid())
  garmentTypeId    String
  changedById      String
  oldCustomerPrice Int?
  oldEmployeeRate  Int?
  newCustomerPrice Int?
  newEmployeeRate  Int?
  action           String
  createdAt        DateTime    @default(now())
  changedBy        User        @relation(fields: [changedById], references: [id])
  garmentType      GarmentType @relation(fields: [garmentTypeId], references: [id])

  @@index([garmentTypeId])
  @@index([createdAt])
}

model WorkflowStepTemplate {
  id            String          @id @default(cuid())
  garmentTypeId String
  stepKey       String
  stepName      String
  sortOrder     Int             @default(0)
  isRequired    Boolean         @default(true)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  deletedAt     DateTime?
  tasks         OrderItemTask[]
  rateCards     RateCard[]
  garmentType   GarmentType     @relation(fields: [garmentTypeId], references: [id])

  @@unique([garmentTypeId, stepKey])
  @@index([garmentTypeId, sortOrder])
}

model RateCard {
  id             String                @id @default(cuid())
  branchId       String?
  garmentTypeId  String
  stepTemplateId String?
  stepKey        String
  rate           Int
  effectiveFrom  DateTime              @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?
  tasks          OrderItemTask[]
  branch         Branch?               @relation(fields: [branchId], references: [id])
  garmentType    GarmentType           @relation(fields: [garmentTypeId], references: [id])
  stepTemplate   WorkflowStepTemplate? @relation(fields: [stepTemplateId], references: [id])

  @@index([branchId, garmentTypeId, stepKey])
  @@index([effectiveFrom, effectiveTo])
}

model OrderItemTask {
  id                 String                         @id @default(cuid())
  orderItemId        String
  stepTemplateId     String?
  stepKey            String
  stepName           String
  sortOrder          Int                            @default(0)
  status             TaskStatus                     @default(PENDING)
  assignedEmployeeId String?
  startedAt          DateTime?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  deletedAt          DateTime?
  rateCardId         String?
  rateOverride       Int?
  rateSnapshot       Int?
  assignedEmployee   Employee?                      @relation(fields: [assignedEmployeeId], references: [id])
  orderItem          OrderItem                      @relation(fields: [orderItemId], references: [id])
  rateCard           RateCard?                      @relation(fields: [rateCardId], references: [id])
  stepTemplate       WorkflowStepTemplate?          @relation(fields: [stepTemplateId], references: [id])
  assignmentEvents   OrderItemTaskAssignmentEvent[]

  @@index([orderItemId, sortOrder])
  @@index([assignedEmployeeId, status])
  @@index([stepKey])
}

model OrderItemTaskAssignmentEvent {
  id             String        @id @default(cuid())
  taskId         String
  fromEmployeeId String?
  toEmployeeId   String?
  changedById    String?
  note           String?
  createdAt      DateTime      @default(now())
  changedBy      User?         @relation(fields: [changedById], references: [id])
  task           OrderItemTask @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

model SystemSettings {
  id              String   @id @default("default")
  useTaskWorkflow Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ENTRY_OPERATOR
  VIEWER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  LEFT
}

enum PaymentType {
  PER_PIECE
  WEEKLY_FIXED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum FieldType {
  NUMBER
  TEXT
  DROPDOWN
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  READY
  OVERDUE
  DELIVERED
  COMPLETED
  CANCELLED
}

enum ItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum FabricSource {
  SHOP
  CUSTOMER
}
