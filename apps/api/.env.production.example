# API production env template
NODE_ENV=production
TZ=Asia/Karachi
PORT=8080

DATABASE_URL=postgresql://user:password@db-host:5432/tbms?schema=public
DIRECT_URL=postgresql://user:password@db-host:5432/tbms?schema=public

REDIS_URL=rediss://username:password@redis-host:6379
TRUST_PROXY=1

FRONTEND_URL=https://app.example.com

JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-random-secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_ROTATION_GRACE_SECONDS=30
STATUS_PIN_PEPPER=replace-with-strong-random-secret
ENABLE_INTERNAL_SCHEDULER=true
SEED_CORE_DATA=false
SEED_DEMO_DATA=false

ENABLE_PUBLIC_MAIL_ENDPOINTS=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_EMAIL=
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
