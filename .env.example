# Database (Neon pooled connection / local postgres)
# Local Postgres DB:
DATABASE_URL=postgresql://tbms:password@localhost:5432/tbms?schema=public
DIRECT_URL=postgresql://tbms:password@localhost:5432/tbms?schema=public

# Neon examples:
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech:6543/tbms?pgbouncer=true
# DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech:5432/tbms

# Redis (Local or Upstash)
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:token@endpoint.upstash.io:6380

# JWT
JWT_SECRET=super-secret-jwt-key-for-development-only
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=different-super-secret-refresh-key
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2 / Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tbms-files
R2_PUBLIC_URL=http://localhost:3000/uploads

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
INTERNAL_API_URL=http://localhost:3001
NEXTAUTH_SECRET=dev-only-nextauth-secret-change-me
ENABLE_PUBLIC_MAIL_ENDPOINTS=true
TZ=Asia/Karachi
