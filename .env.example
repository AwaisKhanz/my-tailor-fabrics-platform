# Deprecated root env template for runtime.
#
# This repository now uses app-scoped env templates:
# - apps/api/.env.example
# - apps/api/.env.local.example
# - apps/api/.env.production.example
# - apps/web/.env.example
# - apps/web/.env.local.example
# - apps/web/.env.production.example
#
# Initialize local runtime env files with:
#   npm run env:setup
# Then validate:
#   npm run env:verify
