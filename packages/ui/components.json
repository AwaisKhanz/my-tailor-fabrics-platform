{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@tbms/ui/components",
    "utils": "@tbms/ui/lib/utils",
    "ui": "@tbms/ui/components",
    "lib": "@tbms/ui/lib",
    "hooks": "@tbms/ui/hooks"
  },
  "registries": {
    "@efferd": "https://efferd.com/r/{name}.json",
    "@manifest": "https://ui.manifest.build/r/{name}.json",
    "@moleculeui": "https://www.moleculeui.design/r/{name}.json",
    "@optics": "https://optics.agusmayol.com.ar/r/{name}.json",
    "@pacekit": "https://ui.pacekit.dev/r/{name}.json",
    "@reui": "https://reui.io/r/{style}/{name}.json"
  }
}
